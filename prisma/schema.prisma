generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  role          String    @default("USER") // USER, ADMIN
  apps          App[]
  accounts      Account[]
  sessions      Session[]
  reviews       Review[]
  launches      LaunchLog[]
}

model Account {
  id                 String  @id @default(cuid())
  userId             String
  type               String
  provider           String
  providerAccountId  String
  refresh_token      String?
  access_token       String?
  expires_at         Int?
  token_type         String?
  scope              String?
  id_token           String?
  session_state      String?
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model App {
  id           String   @id @default(uuid())
  name         String
  description  String
  category     String?
  icon         String?
  color        String?
  localPath    String
  dockerImage  String
  internalPort Int      @default(3000)
  status       String   @default("PENDING")
  authorId     String?
  author       User?    @relation(fields: [authorId], references: [id])
  reviews      Review[]
  launches     LaunchLog[]
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model Review {
  id        String   @id @default(cuid())
  rating    Int
  comment   String?
  userId    String
  appId     String
  user      User     @relation(fields: [userId], references: [id])
  app       App      @relation(fields: [appId], references: [id])
  createdAt DateTime @default(now())
}

model LaunchLog {
  id        String   @id @default(cuid())
  userId    String?
  appId     String
  user      User?    @relation(fields: [userId], references: [id])
  app       App      @relation(fields: [appId], references: [id])
  createdAt DateTime @default(now())
}
