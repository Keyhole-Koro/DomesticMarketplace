generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model App {
  id           String   @id @default(uuid())
  name         String
  description  String
  category     String?
  icon         String?
  color        String?
  localPath    String
  dockerImage  String
  internalPort Int      @default(3000)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}
